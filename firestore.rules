rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /leads/{leadId} {
      function isValidLead(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
               data.status in ['novo', 'contatado', 'interessado', 'fechado', 'arquivado'] &&
               data.ownerId == request.auth.uid &&
               (data.get('phone', '') is string) &&
               (data.get('email', '') is string) &&
               (data.get('address', '') is string) &&
               (data.get('niche', '') is string);
      }

      allow get: if isOwner(resource.data.ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidLead(request.resource.data) && 
                      request.resource.data.createdAt == request.time;
      
      allow update: if isOwner(resource.data.ownerId) && 
                      isValidLead(request.resource.data) &&
                      request.resource.data.updatedAt == request.time &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      request.resource.data.ownerId == resource.data.ownerId;
      
      allow delete: if isOwner(resource.data.ownerId);
    }
  }
}
